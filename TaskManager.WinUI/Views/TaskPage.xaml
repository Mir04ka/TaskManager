<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TaskManager.WinUI.Views.TaskPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TaskManager.WinUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:BoolToVisibilityConverter        x:Key="BoolToVisConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="{Binding Loc[AddTask]}"
                    Command="{Binding AddTaskCommand}"
                    MinHeight="40"/>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <TextBlock Text="🌐" FontSize="16" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding Loc.AvailableLanguages}"
                            SelectedItem="{Binding Loc.SelectedLanguage, Mode=TwoWay}"
                            Width="120"
                            Height="36"/>
                <Button Content="{Binding Loc[Logout]}"
                        Command="{Binding LogoutCommand}"
                        MinHeight="40"/>
            </StackPanel>
        </Grid>
        
        <!-- Tasks -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Tasks}" Margin="8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <Grid Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="Bold"
                                                   FontSize="15"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"/>
                                        <TextBlock Text="{Binding Description}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="3"
                                                   Margin="0,4,0,0"
                                                   Opacity="0.7"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Vertical"
                                                Spacing="4"
                                                VerticalAlignment="Top"
                                                Margin="12,0,0,0">

                                        <Button Content="{Binding Loc[Edit]}"
                                                Command="{Binding EditCommand}"
                                                HorizontalAlignment="Stretch"
                                                MinWidth="90" MinHeight="36"/>

                                        <Button Content="{Binding Loc[Delete]}"
                                                Command="{Binding DeleteCommand}"
                                                HorizontalAlignment="Stretch"
                                                MinWidth="90" MinHeight="36"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Editing -->
                                <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}" Spacing="4">
                                    <TextBlock Text="Title"/>
                                    <TextBox Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             MaxLength="200"
                                             TextWrapping="Wrap"/>
                                    <TextBlock>
                                        <Run Text="{Binding Title.Length, Mode=OneWay}"/>
                                        <Run Text=" / 200"/>
                                    </TextBlock>

                                    <TextBlock Text="Description" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             MaxLength="1000"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             Height="80"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock>
                                        <Run Text="{Binding Description.Length, Mode=OneWay}"/>
                                        <Run Text=" / 1000"/>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                Margin="0,8,0,0">
                                        <Button Content="{Binding Loc[Save]}"
                                                Command="{Binding SaveCommand}"
                                                MinWidth="90" MinHeight="36"/>
                                        <Button Content="{Binding Loc[Cancel]}"
                                                Command="{Binding CancelCommand}"
                                                MinWidth="90" MinHeight="36"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Pagination -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    Margin="8">
            <Button Content="◀" Command="{Binding PrevPageCommand}"/>
            <TextBlock VerticalAlignment="Center">
                <Run Text="{Binding PageNumber, Mode=OneWay}"/>
                <Run Text=" / "/>
                <Run Text="{Binding TotalPages, Mode=OneWay}"/>
            </TextBlock>
            <Button Content="▶" Command="{Binding NextPageCommand}"/>
        </StackPanel>

    </Grid>
</Page>
