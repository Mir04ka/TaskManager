<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="Username">Username</sys:String>
    <sys:String x:Key="Password">Password</sys:String>
    <sys:String x:Key="Login">Login</sys:String>
    <sys:String x:Key="Register">Register</sys:String>
    <sys:String x:Key="Tasks">Tasks</sys:String>
    <sys:String x:Key="Auth">Authorization</sys:String>
    <sys:String x:Key="Settings">Settings</sys:String>
    <sys:String x:Key="Language">Language</sys:String>
    <sys:String x:Key="AddTask">Add Task</sys:String>
    <sys:String x:Key="Edit">Edit</sys:String>
    <sys:String x:Key="Delete">Delete</sys:String>
    <sys:String x:Key="Save">Save</sys:String>
    <sys:String x:Key="Cancel">Cancel</sys:String>
    <sys:String x:Key="Title">Title</sys:String>
    <sys:String x:Key="Description">Description</sys:String>
    <sys:String x:Key="BackToTasks">Back to Tasks</sys:String>
    <sys:String x:Key="NoDescription">No description</sys:String>
</ResourceDictionary>