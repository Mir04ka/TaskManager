<UserControl x:Class="TaskManager.UI.Views.TaskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TaskManager.UI.Controls"
             xmlns:vm="clr-namespace:TaskManager.UI.ViewModels">

    <DockPanel>
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="5" LastChildFill="False">
            <Button DockPanel.Dock="Left"
                    Content="{DynamicResource AddTask}"
                    Command="{Binding AddTaskCommand}"
                    Margin="5"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
                <TextBlock Text="🌐" FontSize="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding DataContext.SettingsVM.AvailableLanguages, RelativeSource={RelativeSource AncestorType=Window}}"
                          SelectedItem="{Binding DataContext.SettingsVM.SelectedLanguage, RelativeSource={RelativeSource AncestorType=Window}}"
                          Width="60"/>
            </StackPanel>
        </DockPanel>

        <!-- Tasks -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Tasks}" Margin="5">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="5">
                            <StackPanel>
                                <!-- View mode -->
                                <Grid Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Title + description -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}" 
                                                   FontWeight="Bold" 
                                                   FontSize="16" 
                                                   TextWrapping="Wrap" 
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="50"/>
                                        <TextBlock Margin="0,5,0,0" 
                                                   TextWrapping="Wrap" 
                                                   TextTrimming="CharacterEllipsis" 
                                                   MaxHeight="80">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding Description}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Description}" Value="">
                                                            <Setter Property="Text" Value="{DynamicResource NoDescription}"/>
                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                            <Setter Property="Foreground" Value="Gray"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    
                                    <!-- Action buttons -->
                                    <StackPanel Grid.Column="1" 
                                                Orientation="Vertical" 
                                                VerticalAlignment="Top" 
                                                Margin="10,0,0,0">
                                        <Button Command="{Binding EditCommand}" 
                                                MinWidth="100" 
                                                MinHeight="40">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✏ "/>
                                                <TextBlock Text="{DynamicResource Edit}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding DeleteCommand}" 
                                                MinWidth="100" 
                                                MinHeight="40">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🗑 "/>
                                                <TextBlock Text="{DynamicResource Delete}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Edit mode -->
                                <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="{DynamicResource Title}"/>
                                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                             MaxLength="200"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="False"
                                             Margin="0,0,0,5"/>
                                    <TextBlock>
                                        <Run Text="{Binding Title.Length, Mode=OneWay}"/>
                                        <Run Text="/200"/>
                                    </TextBlock>
                                    
                                    <TextBlock Text="{DynamicResource Description}" Margin="0,10,0,0"/>
                                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                                             MaxLength="1000"
                                             TextWrapping="Wrap" 
                                             AcceptsReturn="True" 
                                             Height="80" 
                                             Margin="0,0,0,5"
                                             VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock>
                                        <Run Text="{Binding Description.Length, Mode=OneWay}"/>
                                        <Run Text="/1000"/>
                                    </TextBlock>
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Command="{Binding SaveCommand}" 
                                                MinWidth="100" 
                                                MinHeight="40">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="💾 "/>
                                                <TextBlock Text="{DynamicResource Save}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding CancelCommand}" 
                                                MinWidth="100" 
                                                MinHeight="40">
                                            <TextBlock Text="{DynamicResource Cancel}"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</UserControl>